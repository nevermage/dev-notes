{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "apps/dev-notes/src",
  "compilerOptions": {
    "deleteOutDir": true,
    "webpack": true,
    "tsConfigPath": "apps/dev-notes/tsconfig.app.json"
  },
  "monorepo": true,
  "root": "apps/dev-notes",
  "projects": {
    "common": {
      "type": "library",
      "root": "libs/common",
      "entryFile": "index",
      "sourceRoot": "libs/common/src",
      "compilerOptions": {
        "tsConfigPath": "libs/common/tsconfig.lib.json"
      }
    },
    "dev-notes": {
      "type": "application",
      "root": "apps/dev-notes",
      "entryFile": "main",
      "sourceRoot": "apps/dev-notes/src",
      "compilerOptions": {
        "tsConfigPath": "apps/dev-notes/tsconfig.app.json"
      }
    },
    "search-service": {
      "type": "application",
      "root": "apps/search-service",
      "entryFile": "main",
      "sourceRoot": "apps/search-service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/search-service/tsconfig.app.json"
      }
    }
  }
}